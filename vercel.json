{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "rootDir": "backend",
        "maxDuration": 300,
        "includeFiles": ["**/*.py", "**/*.toml", "requirements.txt"]
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/main.py"
    }
  ]
}