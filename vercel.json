{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "rootDir": "frontend"
      }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "backend/**/*.py",
          "backend/**/*.toml"
        ]
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/main.py"
    }
  ],
  "functions": {
    "backend/main.py": {
      "maxDuration": 300
    }
  }
}