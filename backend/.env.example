# ==============================================================================
# Vampter Backend Configuration Template
# Copy this file to '.env' and fill in the values for local development.
# ==============================================================================

# FastAPI Server Delivery Configuration
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Qdrant Vector Store Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PORT_GRPC=6334
QDRANT_API_KEY=

# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vampter_neo4j_password
NEO4J_AUTH=neo4j/vampter_neo4j_password

# Redis Vector Cache & State Persistence Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Gemini AI / LLM Configuration
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004

# Groq AI / LLM Configuration
GROQ_API_KEY=